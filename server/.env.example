# Server Configuration
PORT=3000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Database & Auth (Supabase)
SUPABASE_URL=your_project_url
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_auth_secret

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=your_ms_client_id
MICROSOFT_TENANT_ID=your_ms_tenant_id
MICROSOFT_SECRET_VALUE=your_ms_secret_value
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# Security & Networking
CORS_ORIGIN=http://localhost:5173
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Internal Microservices
OCR_SERVICE_URL=http://ocr-service:8000
RAG_SERVICE_URL=http://rag-service:8001
BACKEND_WEBHOOK_URL=http://localhost:3000/api

# Storage & Features
UPLOAD_TEMP_DIR=./uploads
USE_MOCK_SERVICES=true